generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  ADMIN
  MEMBER
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BorrowingStatus {
  PENDING
  BORROWED
  RETURN_REQUESTED
  RETURNED
  REJECTED
  LATE
  LOST
}

enum PaymentStatus {
  UNPAID
  PAID
}

model Categories {
  id Int @id @default(autoincrement())
  category_name String @db.VarChar(100)
  is_active Boolean @default(true)
  created_at DateTime @default(now()) @db.Timestamp(0)
  deleted_at DateTime? @db.Timestamp(0)

  books Books[]

  @@map("categories")
}

model Users {
  id Int @id @default(autoincrement())
  email String @db.VarChar(100) @unique
  nik String? @db.VarChar(20)
  password String @db.VarChar(100)
  full_name String @db.VarChar(100)
  address String @db.VarChar(255)
  phone String @db.VarChar(15)
  ktp String? @db.VarChar(255)
  role UserRole @default(MEMBER)
  account_status AccountStatus @default(PENDING)
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt @db.Timestamp(0)
  deleted_at DateTime? @db.Timestamp(0)

  borrowings Borrowings[]
  sessions TokenSessions[]

  @@map("users")
}

model Books {
  id Int @id @default(autoincrement())
  category_id Int
  title String @db.VarChar(255)
  author String @db.VarChar(255)
  publisher String @db.VarChar(150)
  description String? @db.Text
  book_cover String? @db.VarChar(255)
  year Int @db.Year
  total_stock Int
  available Int
  created_at DateTime @default(now()) @db.Timestamp(0)
  deleted_at DateTime? @db.Timestamp(0)

  category Categories @relation(fields: [category_id], references: [id])
  borrowings Borrowings[]

  @@map("books")
}

model Borrowings {
  id String @id @db.VarChar(50)
  user_id Int
  book_id Int
  borrow_date DateTime @db.Date
  due_date DateTime @db.Date
  return_date DateTime? @db.Date
  status BorrowingStatus @default(PENDING)
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt @db.Timestamp(0)

  user Users @relation(fields: [user_id], references: [id])
  book Books @relation(fields: [book_id], references: [id])
  fine Fines?

  @@map("borrowings")
}

model Fines {
  id Int @id @default(autoincrement())
  borrowing_id String @unique
  total_fines Decimal @db.Decimal(10, 2) @default(0.00)
  payment_status PaymentStatus @default(UNPAID)
  payment_date DateTime? @db.Timestamp(0)

  borrowing Borrowings @relation(fields: [borrowing_id], references: [id])

  @@map("fines")
}

model TokenSessions {
  id Int @id @default(autoincrement())
  user_id Int
  token String @db.VarChar(255) @unique
  expires_at DateTime @db.Timestamp(0)
  created_at DateTime @default(now()) @db.Timestamp(0)

  user Users @relation(fields: [user_id], references: [id])

  @@map("token_sessions")
}
