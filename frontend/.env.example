# Kosongkan (default) saat development — Vite akan proxy /api ke backend
# lewat konfigurasi di vite.config.js (server.proxy), jadi tidak perlu diisi.
#
# Isi hanya kalau frontend di-build untuk production dan backend ada di
# domain terpisah, misal:
# VITE_API_URL=https://api.perpustakaan-kamu.com
VITE_API_URL=
